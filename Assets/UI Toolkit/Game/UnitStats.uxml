    <ui:VisualElement name="VisualElement" style="flex-grow: 1; padding-top: 10%; padding-right: 10%; padding-bottom: 10%; padding-left: 10%; background-color: rgba(53, 53, 180, 0); opacity: 0.75; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px; -unity-background-image-tint-color: rgba(124, 124, 124, 0.392); background-repeat: no-repeat no-repeat; background-image: url(&quot;project://database/Assets/Art/Synty/InterfaceFantasyWarriorHUD/Sprites/FantasyWarrior/SPR_FantasyWarrior_Frame_Box_21_Variant_04.png?fileID=2800000&amp;guid=4ef457508d0efe2498883e37bfb6f28a&amp;type=3#SPR_FantasyWarrior_Frame_Box_21_Variant_04&quot;); background-size: 100% 100%; background-position-x: left 0; -unity-background-scale-mode: stretch-to-fill; background-position-y: top 0; -unity-slice-scale: 0; -unity-slice-type: sliced;">
        <ui:VisualElement style="flex-grow: 1; align-self: auto; margin-bottom: 0;">
            <ui:Label text="Unit Name" name="unit-name" class="text" style="overflow: hidden; -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Plugins/Fungus/Fonts/Amaranth/Amaranth-Bold.otf?fileID=12800000&amp;guid=64bd3e45f7a714f16b3c213f55f17fea&amp;type=3#Amaranth-Bold&quot;); font-size: 28%;"/>
